{
	"name": "luau-lsp",
	"version": "2.0.0",
	"description": "Luau LSP for Claude Code with Roblox auto-detection (.luau and .lua)",
	"author": {
		"name": "dig1t",
		"url": "https://github.com/dig1t"
	},
	"lspServers": {
		"luau": {
			"command": "${CLAUDE_PLUGIN_ROOT}/bin/luau-lsp.sh",
			"extensionToLanguage": {
				".luau": "luau",
				".lua": "luau"
			}
		}
	}
}
